generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  name       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  users      User[]

  @@map("roles")
}

model User {
  id             String     @id @default(uuid())
  roleId         Int        @map("role_id")
  role           Role       @relation(fields: [roleId], references: [id])
  fullName       String     @map("full_name")
  email          String     @unique
  passwordHash   String     @map("password_hash")
  phone          String?
  organization   String?
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  rentalRequests   RentalRequest[]
  approvals        Approval[]
  payments         Payment[]
  verifiedPayments Payment[] @relation("PaymentVerifier")

  @@map("users")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId String?  @map("actor_user_id")
  module      String
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt, module])
  @@map("audit_logs")
}

model AssetCategory {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  assets      Asset[]

  @@map("asset_categories")
}

model Asset {
  id                 String             @id @default(uuid())
  assetCode          String             @unique @map("asset_code")
  categoryId         Int                @map("category_id")
  category           AssetCategory      @relation(fields: [categoryId], references: [id])
  name               String
  location           String?
  capacity           Int?
  facilitiesJson     Json?              @map("facilities_json")
  pricingSchemeJson  Json?              @map("pricing_scheme_json")
  availabilityStatus String             @default("AVAILABLE") @map("availability_status") // AVAILABLE, MAINTENANCE, UNAVAILABLE
  description        String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  
  media              AssetMedia[]
  availability       AssetAvailability[]
  rentalRequests     RentalRequest[]

  @@map("assets")
}

model AssetMedia {
  id         String   @id @default(uuid())
  assetId    String   @map("asset_id")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  mediaType  String   @map("media_type") // IMAGE, DOCUMENT
  fileUrl    String   @map("file_url")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("asset_media")
}

model AssetAvailability {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("asset_availability")
}

model RentalRequest {
  id               String             @id @default(uuid())
  requestNo        String             @unique @map("request_no")
  tenantUserId     String             @map("tenant_user_id")
  tenantUser       User               @relation(fields: [tenantUserId], references: [id])
  assetId          String             @map("asset_id")
  asset            Asset              @relation(fields: [assetId], references: [id])
  eventName        String             @map("event_name")
  startDatetime    DateTime           @map("start_datetime")
  endDatetime      DateTime           @map("end_datetime")
  participantCount Int                @map("participant_count")
  purpose          String?
  status           String             @default("DRAFT") // DRAFT, SUBMITTED, PENDING_APPROVAL, APPROVED, REJECTED, REVISION
  submittedAt      DateTime?          @map("submitted_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  documents        RentalRequestDocument[]
  approvals        Approval[]
  statusHistory    StatusHistory[]
  invoice          Invoice?
  contract         Contract?

  @@index([status, startDatetime])
  @@map("rental_requests")
}

model RentalRequestDocument {
  id               String         @id @default(uuid())
  requestId        String         @map("request_id")
  request          RentalRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  docType          String         @map("doc_type") // KTP, SURAT_PENGANTAR, PROPOSAL
  fileUrl          String         @map("file_url")
  verifiedBy       String?        @map("verified_by")
  verifiedAt       DateTime?      @map("verified_at")
  verificationNote String?        @map("verification_note")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@unique([requestId, docType])
  @@map("rental_request_documents")
}

model Approval {
  id               String         @id @default(uuid())
  requestId        String         @map("request_id")
  request          RentalRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverUserId   String         @map("approver_user_id")
  approver         User           @relation(fields: [approverUserId], references: [id])
  action           String         // APPROVE, REJECT, REVISION
  note             String?
  actedAt          DateTime       @default(now()) @map("acted_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@map("approvals")
}

model StatusHistory {
  id               String         @id @default(uuid())
  requestId        String         @map("request_id")
  request          RentalRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromStatus       String?        @map("from_status")
  toStatus         String         @map("to_status")
  changedBy        String?        @map("changed_by")
  note             String?
  createdAt        DateTime       @default(now()) @map("created_at")

  @@map("status_history")
}

model Invoice {
  id               String         @id @default(uuid())
  requestId        String         @unique @map("request_id")
  request          RentalRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  invoiceNo        String         @unique @map("invoice_no")
  issueDate        DateTime       @map("issue_date")
  dueDate          DateTime       @map("due_date")
  subtotal         Float
  utilityCostsJson Json?          @map("utility_costs_json") // Deprecated: digantikan oleh InvoiceItem
  taxAmount        Float          @map("tax_amount")
  penaltyAmount    Float          @default(0) @map("penalty_amount")
  totalAmount      Float          @map("total_amount")
  manualVaNumber   String?        @map("manual_va_number")
  bankName         String?        @map("bank_name") // BNI, BTN
  status           String         @default("UNPAID") // UNPAID, PAID, OVERDUE
  pdfUrl           String?        @map("pdf_url")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  payments         Payment[]
  items            InvoiceItem[]

  @@index([status, dueDate])
  @@map("invoices")
}

model Payment {
  id                  String         @id @default(uuid())
  invoiceId           String         @map("invoice_id")
  invoice             Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payerUserId         String         @map("payer_user_id")
  payer               User           @relation(fields: [payerUserId], references: [id])
  amount              Float
  transferDate        DateTime       @map("transfer_date")
  proofUrl            String         @map("proof_url")
  verificationStatus  String         @default("PENDING") // PENDING, VERIFIED, REJECTED
  verifiedByUserId    String?        @map("verified_by_user_id")
  verifiedByUser      User?          @relation("PaymentVerifier", fields: [verifiedByUserId], references: [id])
  verifiedAt          DateTime?      @map("verified_at")
  verificationNote    String?        @map("verification_note")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@map("payments")
}

model Contract {
  id             String         @id @default(uuid())
  requestId      String         @unique @map("request_id")
  request        RentalRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  contractNo     String         @unique @map("contract_no")
  signedDate     DateTime?      @map("signed_date")
  startDate      DateTime       @map("start_date")
  endDate        DateTime       @map("end_date")
  contractValue  Float          @map("contract_value")
  pdfUrl         String?        @map("pdf_url")
  version        Int            @default(1)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("contracts")
}

model AdditionalAsset {
  id          String   @id @default(uuid())
  assetCode   String   @unique @map("asset_code")
  name        String
  category    String   // e.g., SOUND_SYSTEM, LIGHTING
  price       Float
  stock       Int      @default(1)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("additional_assets")
}

// ===================================================================
// Sprint 2: Invoice Items (Normalisasi utilityCostsJson)
// ===================================================================

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemType    String   @map("item_type") // MAIN_RENTAL, ELECTRICITY, WATER, ADDITIONAL_EQUIPMENT, TAX, LATE_PENALTY
  description String
  amount      Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("invoice_items")
}

// ===================================================================
// Sprint 3: Beban Operasional
// ===================================================================

model ExpenseCategory {
  id          Int                  @id @default(autoincrement())
  code        String               @unique
  name        String
  description String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  expenses    OperationalExpense[]

  @@map("expense_categories")
}

model OperationalExpense {
  id          String          @id @default(uuid())
  categoryId  Int             @map("category_id")
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Float
  periodDate  DateTime        @map("period_date")
  description String?
  receiptUrl  String?         @map("receipt_url")
  createdBy   String?         @map("created_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([categoryId, periodDate])
  @@map("operational_expenses")
}

// ===================================================================
// Sprint 4: Pagu & Penyerapan Anggaran
// ===================================================================

model UnitUsaha {
  id        String        @id @default(uuid())
  code      String        @unique
  name      String
  picName   String?       @map("pic_name")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  budgets   BudgetLimit[]

  @@map("unit_usaha")
}

model BudgetLimit {
  id             String             @id @default(uuid())
  unitUsahaId    String             @map("unit_usaha_id")
  unitUsaha      UnitUsaha          @relation(fields: [unitUsahaId], references: [id])
  allocatedQuota Float              @map("allocated_quota")
  fiscalYear     Int                @map("fiscal_year")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  absorptions    BudgetAbsorption[]

  @@unique([unitUsahaId, fiscalYear])
  @@index([fiscalYear])
  @@map("budget_limits")
}

model BudgetAbsorption {
  id             String      @id @default(uuid())
  budgetLimitId  String      @map("budget_limit_id")
  budgetLimit    BudgetLimit @relation(fields: [budgetLimitId], references: [id], onDelete: Cascade)
  amountAbsorbed Float       @map("amount_absorbed")
  activityName   String      @map("activity_name")
  referenceType  String?     @map("reference_type") // OPERATIONAL_EXPENSE, INTERNAL_ACTIVITY
  referenceId    String?     @map("reference_id")
  receiptUrl     String?     @map("receipt_url")
  absorbedAt     DateTime    @map("absorbed_at")
  createdBy      String?     @map("created_by")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([budgetLimitId, absorbedAt])
  @@map("budget_absorptions")
}

// ===================================================================
// Sprint 5: Revenue Eksternal (Unit Usaha Luar)
// ===================================================================

model ExternalRevenue {
  id              String   @id @default(uuid())
  sourceUnit      String   @map("source_unit") // UNNES_PRESS, PUSLAKES, ASRAMA, BOAB, dll
  amount          Float
  transactionDate DateTime @map("transaction_date")
  referenceNo     String   @unique @map("reference_no")
  description     String?
  importedBy      String?  @map("imported_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([sourceUnit, transactionDate])
  @@map("external_revenues")
}
